{
  "name": "tablsx",
  "version": "0.1.0",
  "description": "A Node.js library for reading and writing Excel .xlsx files",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ test/ examples/",
    "lint:fix": "eslint src/ test/ examples/ --fix",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js' 'examples/**/*.js' 'docs/**/*.md'",
    "format:check": "prettier --check 'src/**/*.js' 'test/**/*.js' 'examples/**/*.js' 'docs/**/*.md'",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.2.3",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "vitepress": "^2.0.0-alpha.12",
    "vitest": "^3.1.1"
  }
}
